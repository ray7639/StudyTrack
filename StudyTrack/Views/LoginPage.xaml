<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudyTrack.ViewModels"
             x:Class="StudyTrack.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <!-- Logo -->
            <Border StrokeThickness="0"
                    BackgroundColor="#3B82F6"
                    WidthRequest="80"
                    HeightRequest="80"
                    HorizontalOptions="Center"
                    Margin="0,60,0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <Label Text="📚"
                       FontSize="40"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <!-- Title -->
            <Label Text="Welcome Back"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="#1F2937"
                   HorizontalOptions="Center" />

            <Label Text="Sign in to continue"
                   FontSize="16"
                   TextColor="#6B7280"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20" />

            <!-- Username Input -->
            <Border StrokeThickness="2"
                    Stroke="#E5E7EB"
                    BackgroundColor="White"
                    Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <Entry Placeholder="Username"
                       Text="{Binding Username}"
                       TextColor="#1F2937"
                       PlaceholderColor="#9CA3AF" />
            </Border>

            <!-- Password Input -->
            <Border StrokeThickness="2"
                    Stroke="#E5E7EB"
                    BackgroundColor="White"
                    Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <Entry Placeholder="Password"
                       Text="{Binding Password}"
                       IsPassword="True"
                       TextColor="#1F2937"
                       PlaceholderColor="#9CA3AF" />
            </Border>

            <!-- Sign In Button -->
            <Button Text="Sign In"
                    Command="{Binding LoginCommand}"
                    BackgroundColor="#3B82F6"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    Padding="15"
                    Margin="0,20,0,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">
                <Button.Shadow>
                    <Shadow Brush="#3B82F6" Opacity="0.3" Radius="10" Offset="0,4" />
                </Button.Shadow>
            </Button>

            <!-- Sign Up Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,20,0,0">
                <Label Text="Don't have an account? "
                       TextColor="#6B7280"
                       FontSize="14" />

                <Label Text="Sign Up"
                       TextColor="#3B82F6"
                       FontSize="14"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
