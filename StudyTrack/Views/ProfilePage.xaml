<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudyTrack.ViewModels"
             x:Class="StudyTrack.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="Profile"
             BackgroundColor="#F9FAFB">
    <ScrollView>
        <VerticalStackLayout Padding="0" Spacing="0">
            <Grid BackgroundColor="#3B82F6" Padding="20,40,20,40">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Border StrokeThickness="0" BackgroundColor="#60A5FA" WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                        <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                        <Label Text="{Binding CurrentUser.Username, Converter={StaticResource InitialsConverter}}" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Text="{Binding CurrentUser.FullName}" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                    <Label Text="{Binding CurrentUser.Email}" FontSize="14" TextColor="#DBEAFE" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
            <Grid Padding="20" ColumnSpacing="15" Margin="0,-20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BackgroundColor="White" Padding="15"><Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding TotalTasks}" TextColor="#3B82F6" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Total" TextColor="#6B7280" FontSize="12" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" BackgroundColor="White" Padding="15"><Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding CompletedTasks}" TextColor="#10B981" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Done" TextColor="#6B7280" FontSize="12" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" BackgroundColor="White" Padding="15"><Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding SuccessRate, StringFormat='{0}%'}" TextColor="#F59E0B" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Rate" TextColor="#6B7280" FontSize="12" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
            <VerticalStackLayout Padding="20" Spacing="10">
                <Label Text="Settings" FontSize="18" FontAttributes="Bold" Margin="0,10,0,10" />
                <Border BackgroundColor="White" Padding="0"><Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="0">
                        <Button Text="✏️ Edit Profile" Command="{Binding EditProfileCommand}" BackgroundColor="Transparent" TextColor="#1F2937" HorizontalOptions="Start" Padding="15" />
                        <BoxView HeightRequest="1" Color="#F3F4F6" />
                        <Button Text="🔒 Change Password" Command="{Binding ChangePasswordCommand}" BackgroundColor="Transparent" TextColor="#1F2937" HorizontalOptions="Start" Padding="15" />
                    </VerticalStackLayout>
                </Border>
                <Button Text="🚪 Logout" Command="{Binding LogoutCommand}" BackgroundColor="#EF4444" TextColor="White" Padding="15" Margin="0,20,0,0" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
