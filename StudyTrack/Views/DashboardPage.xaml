<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudyTrack.ViewModels"
             xmlns:models="clr-namespace:StudyTrack.Models"
             x:Class="StudyTrack.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard"
             BackgroundColor="#F9FAFB">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="0">

            <!-- Header -->
            <Grid BackgroundColor="#3B82F6" Padding="20,20,20,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <VerticalStackLayout Grid.Row="0" Spacing="5">
                    <Label Text="Welcome back,"
                           TextColor="#DBEAFE"
                           FontSize="14" />

                    <Label Text="{Binding UserName}"
                           TextColor="White"
                           FontSize="24"
                           FontAttributes="Bold" />
                </VerticalStackLayout>

                <!-- Search Bar -->
                <Border Grid.Row="1"
                        StrokeThickness="0"
                        BackgroundColor="#60A5FA"
                        Padding="15"
                        Margin="0,20,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <Entry Placeholder="Search tasks..."
                           Text="{Binding SearchQuery}"
                           TextColor="White"
                           PlaceholderColor="#DBEAFE"
                           BackgroundColor="Transparent"
                           ReturnCommand="{Binding SearchCommand}" />
                </Border>
            </Grid>

            <!-- Statistics Cards -->
            <Grid Padding="20,0" ColumnSpacing="15" Margin="0,-20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Active Tasks -->
                <Border Grid.Column="0" BackgroundColor="White" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding ActiveTaskCount}"
                               TextColor="#3B82F6"
                               FontSize="28"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />

                        <Label Text="Active"
                               TextColor="#6B7280"
                               FontSize="12"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Completed Tasks -->
                <Border Grid.Column="1" BackgroundColor="White" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding CompletedTaskCount}"
                               TextColor="#10B981"
                               FontSize="28"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />

                        <Label Text="Done"
                               TextColor="#6B7280"
                               FontSize="12"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Overdue Tasks -->
                <Border Grid.Column="2" BackgroundColor="White" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding OverdueTaskCount}"
                               TextColor="#EF4444"
                               FontSize="28"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />

                        <Label Text="Overdue"
                               TextColor="#6B7280"
                               FontSize="12"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Upcoming Tasks -->
            <VerticalStackLayout Padding="20,0" Spacing="15">
                <Label Text="Upcoming Tasks"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1F2937" />

                <CollectionView ItemsSource="{Binding UpcomingTasks}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TodoTask">
                            <Border BackgroundColor="White"
                                    Padding="15"
                                    Margin="0,0,0,10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=GoToTaskDetailCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Checkbox -->
                                    <Border Grid.Column="0"
                                            StrokeThickness="2"
                                            Stroke="#D1D5DB"
                                            WidthRequest="24"
                                            HeightRequest="24"
                                            VerticalOptions="Start">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>
                                    </Border>

                                    <!-- Task Info -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                                        <Label Text="{Binding Title}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#1F2937" />

                                        <Label Text="{Binding SubjectName}"
                                               FontSize="14"
                                               TextColor="#6B7280" />

                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="⏰"
                                                   FontSize="14" />

                                            <Label Text="{Binding DueDateFormatted}"
                                                   FontSize="14"
                                                   TextColor="{Binding PriorityColor}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- View All Button -->
                <Button Text="View All Tasks"
                        Command="{Binding GoToTasksCommand}"
                        BackgroundColor="#F3F4F6"
                        TextColor="#3B82F6"
                        FontSize="14"
                        Padding="12" />
            </VerticalStackLayout>

            <!-- Add Task Button -->
            <Button Text="+ Add New Task"
                    Command="{Binding GoToAddTaskCommand}"
                    BackgroundColor="#3B82F6"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    Padding="15"
                    Margin="20,10,20,30" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
