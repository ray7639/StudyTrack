<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:StudyTrack.Converters"
             x:Class="StudyTrack.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:BoolToTitleConverter x:Key="BoolToTitleConverter" />
            <converters:BoolToButtonTextConverter x:Key="BoolToButtonTextConverter" />
            <converters:BoolToCompleteTextConverter x:Key="BoolToCompleteTextConverter" />
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:InitialsConverter x:Key="InitialsConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
